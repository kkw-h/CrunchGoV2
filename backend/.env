# 应用配置
PROJECT_NAME=CrunchGo
VERSION=0.1.0

# 安全配置 (生产环境请修改)
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200
ALGORITHM=HS256

# 数据库配置
DATABASE_URL=postgresql+asyncpg://crunchgo:@localhost:5432/crunchgo

# CORS 配置 (逗号分隔)
ALLOWED_HOSTS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# 取餐码配置
PICKUP_CODE_PREFIX=
PICKUP_CODE_DAILY_RESET=true

# 微信小程序配置 (可选)
WECHAT_MINIAPP_ID=wxb86f4b30b7589fc0
WECHAT_MINIAPP_SECRET=2dbb3ab1eb00a732dd577f40d8b030ee
