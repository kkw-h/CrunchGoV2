<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{isLoading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 页面内容 -->
  <block wx:if="{{!isLoading}}">
    <!-- 商家信息卡片 -->
    <view class="merchant-card" wx:if="{{merchantInfo}}">
      <view class="merchant-header">
        <view class="merchant-icon">🏪</view>
        <view class="merchant-info">
          <text class="merchant-name">{{merchantInfo.name || 'CrunchGo'}}</text>
          <text class="merchant-status" wx:if="{{merchantInfo.business_hours}}">
            {{merchantInfo.is_open ? '营业中' : '休息中'}} · {{merchantInfo.business_hours}}
          </text>
        </view>
      </view>
    </view>

    <!-- 商品列表卡片 -->
    <view class="section-card">
      <view class="card-header">
        <text class="card-title">🛒 商品清单</text>
        <text class="item-count">共 {{cart.length}} 件</text>
      </view>

      <view class="cart-list">
        <view wx:for="{{cart}}" wx:key="index" class="cart-item">
          <view class="item-index">{{index + 1}}</view>
          <view class="item-content">
            <view class="item-main">
              <text class="item-name">{{item.name}}</text>
              <view wx:if="{{item.selectedOptions.length > 0}}" class="item-options">
                <text wx:for="{{item.selectedOptions}}" wx:for-item="opt" wx:key="option_id" class="option-tag">
                  {{opt.option_name}}: {{opt.option_value}}
                </text>
              </view>
            </view>
            <view class="item-bottom">
              <text class="item-unit-price">¥{{item.unitPriceYuan}}</text>
              <view class="quantity-control">
                <view class="btn-minus {{item.quantity <= 1 ? 'disabled' : ''}}" bindtap="decreaseQuantity" data-index="{{index}}">
                  <text>-</text>
                </view>
                <text class="quantity">{{item.quantity}}</text>
                <view class="btn-plus" bindtap="increaseQuantity" data-index="{{index}}">
                  <text>+</text>
                </view>
              </view>
              <text class="item-total">¥{{item.itemTotalYuan}}</text>
            </view>
          </view>
          <view class="btn-delete" bindtap="removeItem" data-index="{{index}}">
            <text>×</text>
          </view>
        </view>
      </view>

      <!-- 订单小计 -->
      <view class="order-summary">
        <view class="summary-row">
          <text>商品小计</text>
          <text>¥{{totalPriceYuan}}</text>
        </view>
        <view class="summary-row">
          <text>打包费</text>
          <text>¥0.00</text>
        </view>
        <view class="summary-row total">
          <text>合计</text>
          <text class="total-amount">¥{{totalPriceYuan}}</text>
        </view>
      </view>
    </view>

    <!-- 联系信息卡片 -->
    <view class="section-card">
      <view class="card-header">
        <text class="card-title">👤 联系信息</text>
      </view>
      <view class="form-section">
        <view class="form-item">
          <text class="label required">取餐人</text>
          <input
            type="text"
            placeholder="请输入您的姓名"
            value="{{customerName}}"
            bindinput="onNameInput"
          />
        </view>
        <view class="form-item">
          <text class="label">手机号</text>
          <input
            type="number"
            placeholder="请输入手机号"
            value="{{customerPhone}}"
            bindinput="onPhoneInput"
          />
          <button class="btn-wechat" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">
            一键获取
          </button>
        </view>
      </view>
    </view>

    <!-- 备注卡片 -->
    <view class="section-card">
      <view class="card-header">
        <text class="card-title">📝 订单备注</text>
      </view>
      <view class="remark-section">
        <!-- 快捷备注标签 -->
        <view wx:if="{{quickRemarks.length > 0}}" class="quick-remarks">
          <text class="quick-remarks-title">快捷选择：</text>
          <view class="quick-remarks-list">
            <view
              wx:for="{{quickRemarks}}"
              wx:key="*this"
              class="quick-remark-tag"
              data-remark="{{item}}"
              bindtap="onQuickRemarkTap"
            >
              {{item}}
            </view>
          </view>
        </view>
        <textarea
          class="remark-input"
          placeholder="请输入备注（如：少盐、不要辣、堂食/外带等）"
          value="{{remark}}"
          bindinput="onRemarkInput"
          maxlength="100"
        />
        <text class="remark-count">{{remark.length}}/100</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </block>

  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{!isLoading}}">
    <view class="price-section">
      <view class="price-main">
        <text class="total-label">合计：</text>
        <text class="total-price">¥{{totalPriceYuan}}</text>
      </view>
      <text class="price-detail" bindtap="togglePriceDetail">明细 ></text>
    </view>
    <button
      class="btn-submit {{submitting || cart.length === 0 ? 'disabled' : ''}}"
      bindtap="submitOrder"
      disabled="{{submitting || cart.length === 0}}"
    >
      {{submitting ? '提交中...' : (cart.length === 0 ? '购物车为空' : '提交订单')}}
    </button>
  </view>
</view>
