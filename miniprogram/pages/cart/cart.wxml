<view class="container">
  <!-- 商品列表 -->
  <view class="section-title">商品清单</view>
  <view class="cart-list">
    <view wx:for="{{cart}}" wx:key="index" class="cart-item">
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <view wx:if="{{item.selectedOptions.length > 0}}" class="item-options">
          <text wx:for="{{item.selectedOptions}}" wx:for-item="opt" wx:key="option_id">
            {{opt.option_name}}: {{opt.option_value}}
          </text>
        </view>
        <text class="item-price">¥{{item.unitPriceYuan}}</text>
      </view>

      <view class="item-right">
        <view class="quantity-control">
          <button class="btn-minus" bindtap="decreaseQuantity" data-index="{{index}}">-</button>
          <text class="quantity">{{item.quantity}}</text>
          <button class="btn-plus" bindtap="increaseQuantity" data-index="{{index}}">+</button>
        </view>
        <button class="btn-delete" bindtap="removeItem" data-index="{{index}}">删除</button>
      </view>
    </view>
  </view>

  <button class="btn-clear" bindtap="clearCart">清空购物车</button>

  <!-- 联系信息 -->
  <view class="section-title">联系信息</view>
  <view class="form-section">
    <view class="form-item">
      <text class="label required">姓名</text>
      <input
        type="text"
        placeholder="请输入您的姓名"
        value="{{customerName}}"
        bindinput="onNameInput"
      />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input
        type="number"
        placeholder="请输入手机号"
        value="{{customerPhone}}"
        bindinput="onPhoneInput"
      />
      <button class="btn-wechat" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">
        获取微信手机号
      </button>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section-title">订单备注</view>
  <view class="form-section">
    <textarea
      class="remark-input"
      placeholder="请输入备注（如：少盐、不要辣等）"
      value="{{remark}}"
      bindinput="onRemarkInput"
      maxlength="200"
    />
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar">
    <view class="price-section">
      <text class="total-label">合计：</text>
      <text class="total-price">¥{{totalPriceYuan}}</text>
    </view>
    <button
      class="btn-submit {{submitting ? 'disabled' : ''}}"
      bindtap="submitOrder"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交订单'}}
    </button>
  </view>
</view>
