<view class="container">
  <!-- Tab 栏 -->
  <view class="tab-bar">
    <scroll-view scroll-x class="tab-scroll">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-item {{currentTab === item.key ? 'active' : ''}}"
        bindtap="switchTab"
        data-key="{{item.key}}"
      >
        <text>{{item.label}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-card"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="order-header">
        <text class="order-number">订单号: {{item.order_number}}</text>
        <text class="order-status {{item.status}}">{{statusText[item.status]}}</text>
      </view>

      <view class="order-goods">
        <view wx:for="{{item.items}}" wx:for-item="goods" wx:key="id" class="goods-item">
          <text class="goods-name">{{goods.product_name}}</text>
          <text class="goods-quantity">x{{goods.quantity}}</text>
        </view>
      </view>

      <view class="order-footer">
        <view class="order-time">
          <text>{{formatDateTime(item.created_at)}}</text>
        </view>
        <view class="order-total">
          <text>合计: </text>
          <text class="total-price">¥{{item.totalAmountYuan}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions" catchtap="stopPropagation">
        <button
          wx:if="{{item.status === 'ready'}}"
          class="btn-primary"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          去取餐
        </button>
        <button
          wx:if="{{item.status === 'completed' || item.status === 'cancelled'}}"
          class="btn-outline"
          bindtap="reorder"
          data-order="{{item}}"
        >
          再来一单
        </button>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{orders.length === 0 && !loading}}" class="empty-state">
      <image class="empty-icon" src="/images/empty-order.png" mode="aspectFit"></image>
      <text class="empty-text">暂无订单</text>
      <button class="btn btn-primary" bindtap="goToMenu">去点餐</button>
    </view>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{loading && pagination.page > 1}}" class="loading-more">
    <text>加载中...</text>
  </view>

  <view wx:if="{{!pagination.hasMore && orders.length > 0}}" class="no-more">
    <text>没有更多了</text>
  </view>
</view>