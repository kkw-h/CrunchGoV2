<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <!-- 编辑模式 -->
    <view wx:if="{{isEditing}}" class="user-info edit-mode">
      <button class="avatar-edit-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar" src="{{tempAvatarUrl}}" mode="aspectFill" wx:if="{{tempAvatarUrl}}"></image>
        <view class="avatar-placeholder" wx:else>
          <text>点击上传</text>
        </view>
        <view class="avatar-edit-hint">点击修改</view>
      </button>
      <view class="user-meta">
        <input class="nickname-input" type="nickname" placeholder="请输入昵称" value="{{editNickname}}" bind:input="onNicknameInput" />
      </view>
      <view class="edit-actions">
        <button class="btn-save" bindtap="saveProfile">保存</button>
        <button class="btn-cancel" bindtap="cancelEdit">取消</button>
      </view>
    </view>
    <!-- 展示模式 -->
    <view wx:elif="{{hasUserInfo}}" class="user-info" bindtap="startEdit">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo.avatarUrl}}"></image>
      <view class="avatar-placeholder" wx:else>
        <text>用户</text>
      </view>
      <view class="user-meta">
        <text class="nickname">{{userInfo.nickName || '点击设置昵称'}}</text>
        <text class="hint">点击编辑资料</text>
      </view>
      <text class="edit-icon">✏️</text>
    </view>
    <view wx:else class="user-info" bindtap="promptLogin">
      <view class="avatar-placeholder">
        <text>点击登录</text>
      </view>
      <view class="user-meta">
        <text class="nickname">点击登录</text>
        <text class="hint">登录后享受更多功能</text>
      </view>
    </view>
  </view>

  <!-- 订单统计 -->
  <view class="stats-card">
    <view class="stats-row">
      <view class="stat-item" bindtap="goToOrders">
        <text class="stat-num">{{orderStats.pending}}</text>
        <text class="stat-label">待制作</text>
      </view>
      <view class="stat-item" bindtap="goToOrders">
        <text class="stat-num">{{orderStats.preparing}}</text>
        <text class="stat-label">制作中</text>
      </view>
      <view class="stat-item" bindtap="goToOrders">
        <text class="stat-num">{{orderStats.ready}}</text>
        <text class="stat-label">待取餐</text>
      </view>
      <view class="stat-item" bindtap="goToOrders">
        <text class="stat-num">{{orderStats.total}}</text>
        <text class="stat-label">全部</text>
      </view>
    </view>
  </view>

  <!-- 最近订单 -->
  <view wx:if="{{recentOrders.length > 0}}" class="section">
    <view class="section-header">
      <text class="section-title">最近订单</text>
      <text class="more" bindtap="goToOrders">查看全部 ></text>
    </view>
    <view class="order-list">
      <view wx:for="{{recentOrders}}" wx:key="id" class="order-item" bindtap="goToOrderDetail" data-id="{{item.id}}">
        <view class="order-top">
          <text class="order-code">取餐码: {{item.pickup_code}}</text>
          <text class="order-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="order-goods">
          <text wx:for="{{item.items}}" wx:for-item="goods" wx:key="id">{{goods.product_name}}</text>
        </view>
        <view class="order-bottom">
          <text class="order-time">{{formatTime(item.created_at)}}</text>
          <text class="order-price">¥{{item.totalAmountYuan}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToOrders">
      <image class="menu-icon" src="/images/icon-order.png"></image>
      <text class="menu-text">全部订单</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="viewMerchant">
      <image class="menu-icon" src="/images/icon-shop.png"></image>
      <text class="menu-text">商家信息</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <image class="menu-icon" src="/images/icon-service.png"></image>
      <text class="menu-text">联系客服</text>
      <text class="arrow">></text>
    </view>
    <view wx:if="{{hasUserInfo}}" class="menu-item" bindtap="logout">
      <image class="menu-icon" src="/images/icon-logout.png"></image>
      <text class="menu-text">退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
