<view class="container" wx:if="{{!loading && order}}">
  <!-- 订单状态卡片 -->
  <view class="status-card {{order.status}}">
    <view class="status-header">
      <view class="status-icon-wrapper">
        <text class="status-icon">{{order.status === 'pending' ? '⏳' : order.status === 'preparing' ? '👨‍🍳' : order.status === 'ready' ? '✅' : order.status === 'completed' ? '✓' : '✕'}}</text>
      </view>
      <view class="status-info">
        <text class="status-text">{{statusText[order.status]}}</text>
        <text wx:if="{{order.status === 'ready'}}" class="status-hint">请向店员出示取餐码</text>
        <text wx:elif="{{order.status === 'pending'}}" class="status-hint">商家已收到订单，准备制作</text>
        <text wx:elif="{{order.status === 'preparing'}}" class="status-hint">正在为您精心制作</text>
        <text wx:elif="{{order.status === 'completed'}}" class="status-hint">期待您的再次光临</text>
        <text wx:elif="{{order.status === 'cancelled'}}" class="status-hint">订单已取消</text>
      </view>
    </view>

    <!-- 状态进度条 -->
    <view class="status-progress">
      <view class="progress-step {{order.status === 'pending' || order.status === 'preparing' || order.status === 'ready' || order.status === 'completed' ? 'active' : ''}} {{order.status === 'pending' ? 'current' : ''}}">
        <view class="step-dot"></view>
        <text class="step-text">待制作</text>
      </view>
      <view class="progress-line {{order.status === 'preparing' || order.status === 'ready' || order.status === 'completed' ? 'active' : ''}}"></view>
      <view class="progress-step {{order.status === 'preparing' || order.status === 'ready' || order.status === 'completed' ? 'active' : ''}} {{order.status === 'preparing' ? 'current' : ''}}">
        <view class="step-dot"></view>
        <text class="step-text">制作中</text>
      </view>
      <view class="progress-line {{order.status === 'ready' || order.status === 'completed' ? 'active' : ''}}"></view>
      <view class="progress-step {{order.status === 'ready' || order.status === 'completed' ? 'active' : ''}} {{order.status === 'ready' ? 'current' : ''}}">
        <view class="step-dot"></view>
        <text class="step-text">待取餐</text>
      </view>
      <view class="progress-line {{order.status === 'completed' ? 'active' : ''}}"></view>
      <view class="progress-step {{order.status === 'completed' ? 'active' : ''}} {{order.status === 'completed' ? 'current' : ''}}">
        <view class="step-dot"></view>
        <text class="step-text">已完成</text>
      </view>
    </view>
  </view>

  <!-- 取餐码 -->
  <view wx:if="{{order.status !== 'cancelled'}}" class="pickup-card">
    <view class="pickup-header">
      <view class="pickup-date">
        <text class="date-value">{{order.orderDateStr || '--'}}</text>
      </view>
      <view class="pickup-badge" wx:if="{{order.status === 'ready'}}">可取餐</view>
    </view>
    <view class="pickup-code-wrapper">
      <text class="pickup-code">{{order.pickup_code}}</text>
    </view>
    <view class="pickup-hint">
      <text class="hint-icon">📷</text>
      <text>请截图保存，到店出示</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-card">
    <view class="card-header">
      <view class="card-title-icon">🛒</view>
      <text class="card-title">商品明细</text>
    </view>
    <view wx:for="{{order.items}}" wx:key="id" class="goods-item">
      <view class="goods-main">
        <view class="goods-index">{{index + 1}}</view>
        <view class="goods-info">
          <text class="goods-name">{{item.product_name}}</text>
          <view wx:if="{{item.selected_options.length > 0}}" class="goods-options">
            <view wx:for="{{item.selected_options}}" wx:for-item="opt" class="option-chip">
              <text class="option-name">{{opt.option_name}}</text>
              <text class="option-dot">·</text>
              <text class="option-value">{{opt.option_value}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="goods-right">
        <text class="goods-price">¥{{item.productPriceYuan}}</text>
        <text class="goods-quantity">× {{item.quantity}}</text>
      </view>
    </view>

    <view wx:if="{{order.note}}" class="order-note">
      <view class="note-header">
        <text class="note-icon">📝</text>
        <text class="note-label">订单备注</text>
      </view>
      <text class="note-content">{{order.note}}</text>
    </view>

    <view class="total-section">
      <view class="total-row">
        <text class="total-label">商品小计</text>
        <text class="total-value">¥{{order.totalAmountYuan}}</text>
      </view>
      <view class="total-row final">
        <text class="total-label">实付金额</text>
        <text class="total-price">¥{{order.totalAmountYuan}}</text>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="info-card">
    <view class="card-header">
      <view class="card-title-icon">📋</view>
      <text class="card-title">订单信息</text>
    </view>
    <view class="info-list">
      <view class="info-row">
        <text class="label">订单编号</text>
        <view class="value-wrapper">
          <text class="value">{{order.order_number}}</text>
          <text class="copy-btn" bindtap="copyOrderNumber">复制</text>
        </view>
      </view>
      <view class="info-row">
        <text class="label">下单时间</text>
        <text class="value">{{order.formattedCreatedAt || '--'}}</text>
      </view>
      <view wx:if="{{order.customer_name}}" class="info-row">
        <text class="label">取餐人</text>
        <text class="value">{{order.customer_name}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button wx:if="{{order.status === 'pending'}}" class="btn-cancel" bindtap="cancelOrder">
      <text class="btn-icon">🗑️</text>
      <text>取消订单</text>
    </button>
    <button wx:if="{{order.status === 'completed' || order.status === 'cancelled'}}" class="btn-primary" bindtap="reorder">
      <text class="btn-icon">↺</text>
      <text>再来一单</text>
    </button>
    <button wx:if="{{order.status !== 'cancelled'}}" class="btn-primary {{order.status === 'completed' ? 'btn-full' : ''}}" bindtap="contactMerchant">
      <text class="btn-icon">📞</text>
      <text>联系商家</text>
    </button>
  </view>
</view>

<!-- 加载中 -->
<view wx:if="{{loading}}" class="loading-container">
  <view class="loading">加载中...</view>
</view>
