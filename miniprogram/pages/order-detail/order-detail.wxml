<view class="container" wx:if="{{!loading && order}}">
  <!-- 订单状态卡片 -->
  <view class="status-card {{order.status}}">
    <view class="status-icon">
      <image wx:if="{{order.status === 'pending'}}" src="/images/status-pending.png" mode="aspectFit"></image>
      <image wx:elif="{{order.status === 'preparing'}}" src="/images/status-preparing.png" mode="aspectFit"></image>
      <image wx:elif="{{order.status === 'ready'}}" src="/images/status-ready.png" mode="aspectFit"></image>
      <image wx:elif="{{order.status === 'completed'}}" src="/images/status-completed.png" mode="aspectFit"></image>
      <image wx:elif="{{order.status === 'cancelled'}}" src="/images/status-cancelled.png" mode="aspectFit"></image>
    </view>
    <text class="status-text">{{statusText[order.status]}}</text>
    <view wx:if="{{order.status === 'ready'}}" class="status-hint">
      请向店员出示取餐码
    </view>
  </view>

  <!-- 取餐码 -->
  <view wx:if="{{order.status !== 'cancelled'}}" class="pickup-card">
    <text class="pickup-label">取餐码</text>
    <view class="pickup-code">{{order.pickup_code}}</view>
    <view class="pickup-hint">请截图保存，到店出示</view>
  </view>

  <!-- 订单信息 -->
  <view class="info-card">
    <view class="info-row">
      <text class="label">订单编号</text>
      <text class="value">{{order.order_number}}</text>
    </view>
    <view class="info-row">
      <text class="label">下单时间</text>
      <text class="value">{{formatDateTime(order.created_at)}}</text>
    </view>
    <view wx:if="{{order.customer_name}}" class="info-row">
      <text class="label">联系人</text>
      <text class="value">{{order.customer_name}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-card">
    <view class="card-title">商品明细</view>
    <view wx:for="{{order.items}}" wx:key="id" class="goods-item">
      <view class="goods-info">
        <text class="goods-name">{{item.product_name}}</text>
        <view wx:if="{{item.selected_options.length > 0}}" class="goods-options">
          <text wx:for="{{item.selected_options}}" wx:for-item="opt">{{opt.option_name}}: {{opt.option_value}}</text>
        </view>
      </view>
      <view class="goods-right">
        <text class="goods-price">¥{{item.productPriceYuan}}</text>
        <text class="goods-quantity">x{{item.quantity}}</text>
      </view>
    </view>

    <view wx:if="{{order.note}}" class="order-note">
      <text class="note-label">备注：</text>
      <text class="note-content">{{order.note}}</text>
    </view>

    <view class="total-row">
      <text>合计</text>
      <text class="total-price">¥{{order.totalAmountYuan}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button wx:if="{{order.status === 'pending'}}" class="btn-cancel" bindtap="cancelOrder">取消订单</button>
    <button wx:if="{{order.status === 'completed' || order.status === 'cancelled'}}" class="btn-reorder" bindtap="reorder">再来一单</button>
    <button class="btn-contact" bindtap="contactMerchant">联系商家</button>
  </view>
</view>

<!-- 加载中 -->
<view wx:if="{{loading}}" class="loading-container">
  <view class="loading">加载中...</view>
</view>
