/* 页面容器 */
.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 状态卡片 */
.status-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.status-card.pending {
  background: linear-gradient(180deg, #fff5f0 0%, #fff 100%);
  border: 2rpx solid #ffd9c7;
}

.status-card.preparing {
  background: linear-gradient(180deg, #f0f9ff 0%, #fff 100%);
  border: 2rpx solid #bae0ff;
}

.status-card.ready {
  background: linear-gradient(180deg, #f6ffed 0%, #fff 100%);
  border: 2rpx solid #b7eb8f;
}

.status-card.completed {
  background: linear-gradient(180deg, #f5f5f5 0%, #fff 100%);
  border: 2rpx solid #d9d9d9;
}

.status-card.cancelled {
  background: linear-gradient(180deg, #fff1f0 0%, #fff 100%);
  border: 2rpx solid #ffa39e;
}

.status-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.status-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.status-card.pending .status-icon-wrapper {
  background: #ff6600;
}

.status-card.preparing .status-icon-wrapper {
  background: #1890ff;
}

.status-card.ready .status-icon-wrapper {
  background: #52c41a;
}

.status-card.completed .status-icon-wrapper {
  background: #999;
}

.status-card.cancelled .status-icon-wrapper {
  background: #ff4d4f;
}

.status-icon {
  font-size: 48rpx;
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.status-card.pending .status-text {
  color: #ff6600;
}

.status-card.preparing .status-text {
  color: #1890ff;
}

.status-card.ready .status-text {
  color: #52c41a;
}

.status-card.completed .status-text {
  color: #999;
}

.status-card.cancelled .status-text {
  color: #ff4d4f;
}

.status-hint {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 状态进度条 */
.status-progress {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 10rpx;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.progress-step .step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e0e0e0;
  position: relative;
}

.progress-step.active .step-dot {
  background: #52c41a;
}

.progress-step.current .step-dot {
  width: 28rpx;
  height: 28rpx;
  background: #ff6600;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 0, 0.3);
}

.progress-step.current .step-dot::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  background: #fff;
  border-radius: 50%;
}

.progress-step .step-text {
  font-size: 22rpx;
  color: #999;
}

.progress-step.active .step-text {
  color: #52c41a;
}

.progress-step.current .step-text {
  color: #ff6600;
  font-weight: bold;
}

.progress-line {
  flex: 1;
  height: 4rpx;
  background: #e0e0e0;
  margin: 0 10rpx;
  margin-bottom: 32rpx;
}

.progress-line.active {
  background: #52c41a;
}

/* 取餐码卡片 */
.pickup-card {
  background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 102, 0, 0.2);
}

.pickup-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.pickup-date {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.date-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.pickup-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.pickup-badge {
  font-size: 22rpx;
  color: #ff6600;
  background: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.pickup-code-wrapper {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.pickup-code {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 10rpx;
  text-align: center;
  display: block;
}

.pickup-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hint-icon {
  font-size: 28rpx;
}

/* 通用卡片样式 */
.info-card,
.goods-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  margin-bottom: 20rpx;
}

.card-title-icon {
  font-size: 32rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.copy-btn {
  font-size: 24rpx;
  color: #ff6600;
  background: #fff5f0;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #ffd9c7;
}

/* 商品列表 */
.goods-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.goods-item:last-of-type {
  border-bottom: none;
}

.goods-main {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
}

.goods-index {
  width: 36rpx;
  height: 36rpx;
  background: #fff5f0;
  color: #ff6600;
  font-size: 22rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  line-height: 1.4;
}

.goods-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.option-chip {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #fff5f0 0%, #fff 100%);
  border: 1rpx solid #ffd9c7;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
}

.option-name {
  font-size: 22rpx;
  color: #999;
}

.option-dot {
  font-size: 20rpx;
  color: #ffaa80;
  margin: 0 6rpx;
}

.option-value {
  font-size: 22rpx;
  color: #ff6600;
  font-weight: 500;
}

.goods-right {
  text-align: right;
  flex-shrink: 0;
}

.goods-price {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.goods-quantity {
  font-size: 24rpx;
  color: #999;
}

/* 订单备注 */
.order-note {
  margin-top: 20rpx;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
}

.note-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.note-icon {
  font-size: 26rpx;
}

.note-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.note-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 合计区域 */
.total-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 4rpx solid #f5f5f5;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.total-row.final {
  padding-top: 20rpx;
  margin-top: 12rpx;
  border-top: 2rpx dashed #e0e0e0;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-value {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6600;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-bar button {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  transition: all 0.2s;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 102, 0, 0.25);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 0, 0.2);
}

.btn-secondary {
  background: linear-gradient(135deg, #fff5f0 0%, #fff 100%);
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.1);
}

.btn-secondary:active {
  background: linear-gradient(135deg, #ffeae8 0%, #fff5f0 100%);
  transform: scale(0.98);
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 3rpx solid #ff4d4f;
  background: #fff;
  color: #ff4d4f;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.15);
  transition: all 0.2s;
}

.btn-cancel:active {
  background: #fff5f5;
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.1);
}

.btn-full {
  flex: 1;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f5f5f5;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.loading::before {
  content: '';
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #ff6600;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
