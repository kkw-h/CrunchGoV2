.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 状态卡片 */
.status-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.status-card.pending {
  background: #fff5f0;
}

.status-card.preparing {
  background: #f0f9ff;
}

.status-card.ready {
  background: #f6ffed;
}

.status-card.completed {
  background: #f5f5f5;
}

.status-card.cancelled {
  background: #fff1f0;
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 20rpx;
}

.status-icon image {
  width: 100%;
  height: 100%;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.status-card.pending .status-text {
  color: #ff6600;
}

.status-card.preparing .status-text {
  color: #1890ff;
}

.status-card.ready .status-text {
  color: #52c41a;
}

.status-card.completed .status-text {
  color: #999;
}

.status-card.cancelled .status-text {
  color: #ff4d4f;
}

.status-hint {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}

/* 取餐码卡片 */
.pickup-card {
  background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.pickup-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 20rpx;
}

.pickup-code {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 10rpx;
  margin-bottom: 20rpx;
}

.pickup-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 信息卡片 */
.info-card,
.goods-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
}

/* 商品卡片 */
.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.goods-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.goods-info {
  flex: 1;
  margin-right: 20rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.goods-options {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.goods-options text {
  font-size: 24rpx;
  color: #999;
}

.goods-right {
  text-align: right;
}

.goods-price {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.goods-quantity {
  font-size: 24rpx;
  color: #999;
}

.order-note {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.note-label {
  font-size: 26rpx;
  color: #666;
}

.note-content {
  font-size: 26rpx;
  color: #333;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 4rpx solid #f5f5f5;
  font-size: 30rpx;
  color: #333;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6600;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
}

.action-bar button {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel {
  background: #fff1f0;
  color: #ff4d4f;
}

.btn-reorder,
.btn-contact {
  background: #ff6600;
  color: #fff;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading {
  font-size: 28rpx;
  color: #999;
}
