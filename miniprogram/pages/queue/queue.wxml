<view class="container">
  <view class="tab-content">
    <!-- 刷新按钮 -->
    <view class="refresh-bar">
      <view class="refresh-info">
        <text class="refresh-text">{{countdown}}秒后刷新</text>
      </view>
      <view class="refresh-btn {{loading ? 'loading' : ''}}" bindtap="refreshQueue">
        <text class="refresh-icon">↻</text>
        <text class="refresh-btn-text">刷新</text>
      </view>
    </view>

    <view class="queue-stats">
      <view class="stat-item">
        <text class="stat-num">{{queueData.pending.length}}</text>
        <text class="stat-label">待制作</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{queueData.preparing.length}}</text>
        <text class="stat-label">制作中</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{queueData.ready.length}}</text>
        <text class="stat-label">待取餐</text>
      </view>
    </view>

    <!-- 待取餐（优先显示） -->
    <view wx:if="{{queueData.ready.length > 0}}" class="queue-section">
      <view class="section-title ready">
        <text>待取餐</text>
        <text class="count">{{queueData.ready.length}}</text>
      </view>
      <view class="order-list">
        <view wx:for="{{queueData.ready}}" wx:key="id" class="order-card ready" bindtap="goToOrderDetail" data-id="{{item.id}}">
          <view class="order-main">
            <text class="pickup-code">{{item.pickup_code}}</text>
            <view class="order-info">
              <text class="product-names">{{item.productNames}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 制作中 -->
    <view wx:if="{{queueData.preparing.length > 0}}" class="queue-section">
      <view class="section-title preparing">
        <text>制作中</text>
        <text class="count">{{queueData.preparing.length}}</text>
      </view>
      <view class="order-list">
        <view wx:for="{{queueData.preparing}}" wx:key="id" class="order-card preparing" bindtap="goToOrderDetail" data-id="{{item.id}}">
          <view class="order-main">
            <text class="pickup-code">{{item.pickup_code}}</text>
            <view class="order-info">
              <text class="product-names">{{item.productNames}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 待制作 -->
    <view wx:if="{{queueData.pending.length > 0}}" class="queue-section">
      <view class="section-title pending">
        <text>待制作</text>
        <text class="count">{{queueData.pending.length}}</text>
      </view>
      <view class="order-list">
        <view wx:for="{{queueData.pending}}" wx:key="id" class="order-card pending" bindtap="goToOrderDetail" data-id="{{item.id}}">
          <view class="order-main">
            <text class="pickup-code">{{item.pickup_code}}</text>
            <view class="order-info">
              <text class="product-names">{{item.productNames}}</text>
              <text wx:if="{{item.aheadCount > 0}}" class="ahead-count">前面还有 {{item.aheadCount}} 单</text>
              <text wx:else class="ahead-count first">正在为您准备</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{queueData.pending.length === 0 && queueData.preparing.length === 0 && queueData.ready.length === 0}}" class="empty-state">
      <image class="empty-icon" src="/images/empty-queue.png" mode="aspectFit"></image>
      <text class="empty-text">当前没有排队的订单</text>
      <button class="btn btn-primary" bindtap="goToMenu">去点餐</button>
    </view>
  </view>
</view>
