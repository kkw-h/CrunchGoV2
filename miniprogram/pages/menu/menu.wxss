.menu-container {
  display: flex;
  height: 100vh;
  background: #f5f5f5;
}

/* 左侧分类 */
.category-sidebar {
  width: 180rpx;
  background: #fff;
  border-right: 2rpx solid #f0f0f0;
}

.category-scroll {
  height: 100%;
}

.category-item {
  padding: 30rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  border-left: 6rpx solid transparent;
  transition: all 0.2s;
}

.category-item.active {
  background: #f5f5f5;
  color: #ff6600;
  border-left-color: #ff6600;
  font-weight: bold;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  background: #f5f5f5;
}

.product-scroll {
  height: 100%;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.products {
  padding: 20rpx;
}

.product-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #ff6600;
  background: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6600;
}

.product-stock-row {
  display: flex;
  align-items: center;
}

.stock-warning {
  font-size: 22rpx;
  color: #ff4d4f;
}

.stock-normal {
  font-size: 22rpx;
  color: #999;
}

.btn-add {
  width: 56rpx;
  height: 56rpx;
  background: #ff6600;
  color: #fff;
  border-radius: 50%;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 56rpx;
  margin-left: auto;
  margin-right: 0;
}

/* 购物车底部栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.cart-icon {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 102, 0, 0.3);
  transition: transform 0.1s, box-shadow 0.2s;
}

.cart-icon:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 102, 0, 0.2);
}

.cart-icon.bounce {
  animation: cartBounce 0.4s ease;
}

@keyframes cartBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.cart-icon image {
  width: 48rpx;
  height: 48rpx;
  filter: brightness(0) invert(1);
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border: 2rpx solid #fff;
}

.cart-info {
  flex: 1;
  margin-left: 20rpx;
}

.cart-total {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6600;
}

.cart-empty {
  font-size: 28rpx;
  color: #999;
}

.btn-checkout {
  width: 200rpx;
  height: 72rpx;
  background: #ff6600;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-checkout.disabled {
  background: #ccc;
}

/* 购物车弹窗 */
.cart-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  backdrop-filter: blur(4rpx);
}

.cart-detail {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.cart-detail.show {
  transform: translateY(0);
}

/* 拖动条 */
.drag-bar {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
}

.drag-handle {
  width: 72rpx;
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 30rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  flex-shrink: 0;
}

.cart-title {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.cart-count {
  font-size: 26rpx;
  color: #999;
}

.clear-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #999;
  font-size: 26rpx;
  padding: 10rpx 16rpx;
}

.delete-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

.cart-items {
  max-height: 52vh;
  padding: 10rpx 30rpx;
  box-sizing: border-box;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-item:last-child {
  border-bottom: none;
}

.item-main {
  flex: 1;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
}

.item-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.option-tag {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.item-unit-price {
  font-size: 24rpx;
  color: #999;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
  min-width: 160rpx;
}

.item-price {
  font-size: 32rpx;
  color: #ff6600;
  font-weight: bold;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f8f8f8;
  border-radius: 28rpx;
  padding: 6rpx;
}

.btn-minus, .btn-plus {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-minus {
  background: #fff;
}

.btn-minus.disabled {
  opacity: 0.4;
}

.btn-minus text, .btn-plus text {
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
}

.btn-minus text {
  color: #333;
}

.btn-plus {
  background: #ff6600;
}

.btn-plus text {
  color: #fff;
}

.quantity-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  min-width: 36rpx;
  text-align: center;
}

/* 空状态 */
.cart-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-cart-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-cart-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-cart-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 购物车弹窗底部结算栏 */
/* 购物车弹窗底部结算栏 - 与底部购物车栏保持一致 */
.cart-popup-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx calc(env(safe-area-inset-bottom));
  border-top: 2rpx solid #f0f0f0;
  background: #fff;
  flex-shrink: 0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.cart-popup-info {
  display: flex;
  align-items: baseline;
}

.popup-total-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
}

.popup-total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6600;
}

.btn-popup-checkout {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #ff6600;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
}

.btn-popup-checkout::after {
  border: none;
}

/* 商品选项弹窗 */
.product-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.product-detail {
  width: 100%;
  max-height: 80%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: relative;
}

.modal-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-right: 20rpx;
}

.modal-title {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.modal-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.modal-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6600;
}

.btn-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  font-size: 40rpx;
  color: #999;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  max-height: 500rpx;
  padding: 30rpx;
}

.option-section {
  margin-bottom: 30rpx;
}

.option-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.option-title .required {
  font-size: 22rpx;
  color: #ff4d4f;
  background: #fff1f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.option-values {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-value {
  padding: 16rpx 30rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.option-value.selected {
  background: #fff5f0;
  color: #ff6600;
  border-color: #ff6600;
}

.extra-price {
  margin-left: 8rpx;
  font-size: 24rpx;
}

.modal-footer {
  padding: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  background: #ff6600;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
