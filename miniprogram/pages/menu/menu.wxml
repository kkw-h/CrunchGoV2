<view class="menu-container">
  <!-- 左侧分类导航 -->
  <view class="category-sidebar">
    <scroll-view scroll-y class="category-scroll">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{currentCategory === item.id ? 'active' : ''}}"
        bindtap="switchCategory"
        data-id="{{item.id}}"
      >
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 右侧商品列表 -->
  <view class="product-list">
    <scroll-view scroll-y class="product-scroll" scroll-into-view="product-{{highlightProductId}}">
      <view wx:if="{{loading}}" class="loading">加载中...</view>

      <view wx:else class="products">
        <view
          wx:for="{{products}}"
          wx:key="id"
          id="product-{{item.id}}"
          class="product-card"
          bindtap="selectProduct"
          data-product="{{item}}"
        >
          <image class="product-image" src="{{item.image_url || '/images/default-food.png'}}" mode="aspectFill"></image>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-desc">{{item.description}}</text>
            <view class="product-tags" wx:if="{{item.options && item.options.length > 0}}">
              <text class="tag" wx:for="{{item.options}}" wx:for-item="opt" wx:key="id">{{opt.name}}</text>
            </view>
            <view class="product-price-row">
              <text class="product-price">¥{{item.priceYuan}}</text>
              <button class="btn-add" disabled="{{item.stock === 0}}" style="{{item.stock === 0 ? 'background: #ccc;' : ''}}">+</button>
            </view>
            <view class="product-stock-row">
              <text wx:if="{{item.stock <= 10 && item.stock > 0}}" class="stock-warning">仅剩{{item.stock}}份</text>
              <text wx:elif="{{item.stock === 0}}" class="stock-warning" style="color: #999;">暂时缺货</text>
              <text wx:else class="stock-normal">库存{{item.stock}}份</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部占位 -->
      <view style="height: 120rpx;"></view>
    </scroll-view>
  </view>

  <!-- 购物车底部栏 -->
  <view class="cart-bar">
    <view class="cart-icon" bindtap="toggleCartDetail">
      <image src="/images/cart.png" mode="aspectFit"></image>
      <view wx:if="{{cart.length > 0}}" class="cart-badge">{{cartCount}}</view>
    </view>
    <view class="cart-info" bindtap="toggleCartDetail">
      <text wx:if="{{cart.length > 0}}" class="cart-total">¥{{cartTotalYuan}}</text>
      <text wx:else class="cart-empty">购物车是空的</text>
    </view>

    <button
      class="btn-checkout {{cart.length > 0 ? '' : 'disabled'}}"
      bindtap="goToCheckout"
    >去结算</button>
  </view>

  <!-- 购物车详情弹窗 -->
  <view wx:if="{{showCartDetail}}" class="cart-modal" bindtap="closeCartDetail">
    <view class="cart-detail {{showCartDetail ? 'show' : ''}}" catchtap="preventClose">
      <!-- 拖动条 -->
      <view class="drag-bar" bindtap="closeCartDetail">
        <view class="drag-handle"></view>
      </view>

      <view class="cart-header">
        <view class="cart-title">
          <text class="title-text">已选商品</text>
          <text class="cart-count">共 {{cartCount}} 件</text>
        </view>
        <view class="clear-btn" bindtap="clearCart">
          <image src="/images/icon-delete.png" mode="aspectFit" class="delete-icon"></image>
          <text>清空</text>
        </view>
      </view>

      <scroll-view scroll-y class="cart-items" enable-flex>
        <!-- 空状态 -->
        <view wx:if="{{cart.length === 0}}" class="cart-empty-state">
          <view class="empty-cart-icon">🛒</view>
          <text class="empty-cart-text">购物车是空的</text>
          <text class="empty-cart-hint">快去选购心仪的商品吧</text>
        </view>

        <view wx:for="{{cart}}" wx:key="index" class="cart-item">
          <view class="item-main">
            <text class="item-name">{{item.name}}</text>
            <view wx:if="{{item.selectedOptions.length > 0}}" class="item-options">
              <text wx:for="{{item.selectedOptions}}" wx:for-item="opt" wx:key="index" class="option-tag">{{opt.option_name}}: {{opt.option_value}}</text>
            </view>
            <text class="item-unit-price">¥{{item.unitPriceYuan}}/份</text>
          </view>

          <view class="item-right">
            <text class="item-price">¥{{item.itemTotalYuan}}</text>
            <view class="quantity-control">
              <view class="btn-minus {{item.quantity <= 1 ? 'disabled' : ''}}" bindtap="decreaseQuantity" data-index="{{index}}">
                <text>-</text>
              </view>
              <text class="quantity-num">{{item.quantity}}</text>
              <view class="btn-plus" bindtap="increaseQuantity" data-index="{{index}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 底部结算栏 -->
      <view class="cart-popup-footer">
        <view class="cart-popup-info">
          <text class="popup-total-label">合计：</text>
          <text class="popup-total-price">¥{{cartTotalYuan}}</text>
        </view>
        <button class="btn-popup-checkout" bindtap="goToCheckout">去结算</button>
      </view>
    </view>
  </view>

  <!-- 商品选项弹窗 -->
  <view wx:if="{{showProductModal}}" class="product-modal" bindtap="closeProductModal"
  >
    <view class="product-detail" catchtap="preventClose"
    >
      <view class="modal-header"
      >
        <image class="modal-image" src="{{selectedProduct.image_url || '/images/default-food.png'}}" mode="aspectFill"></image>
        <view class="modal-title"
        >
          <text class="modal-name">{{selectedProduct.name}}</text>
          <text class="modal-price">¥{{selectedProduct.priceYuan}}</text>
        </view>
        <button class="btn-close" bindtap="closeProductModal">×</button>
      </view>

      <scroll-view scroll-y class="modal-body"
      >
        <view wx:for="{{selectedProduct.options}}" wx:key="id" class="option-section"
        >
          <view class="option-title"
          >
            <text>{{item.name}}</text>
            <text wx:if="{{item.is_required}}" class="required">必选</text>
          </view>

          <view class="option-values"
          >
            <view
              wx:for="{{item.values}}"
              wx:for-item="value"
              wx:key="id"
              class="option-value {{selectedOptions[item.id] === value.id ? 'selected' : ''}}"
              bindtap="selectOption"
              data-option-id="{{item.id}}"
              data-value-id="{{value.id}}"
            >
              <text>{{value.value}}</text>
              <text wx:if="{{value.extraPriceYuan}}" class="extra-price">+¥{{value.extraPriceYuan}}</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer"
      >
        <button class="btn-confirm" bindtap="confirmAddToCart"
        >加入购物车</button>
      </view>
    </view>
  </view>
</view>
